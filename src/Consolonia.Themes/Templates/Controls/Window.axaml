<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:wm="using:Iciclecreek.Avalonia.WindowManager"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ControlTheme x:Key="{x:Type Window}"
                  TargetType="Window">
        <Setter Property="Background"
                Value="{DynamicResource ThemeBackgroundBrush}" />
        <!--<Setter Property="TransparencyBackgroundFallback" Value="{DynamicResource HighlightForegroundColor}" />-->
        <Setter Property="Foreground"
                Value="{DynamicResource ThemeForegroundBrush}" />
        <Setter Property="FontSize"
                Value="{DynamicResource FontSizeNormal}" />
        <Setter Property="Template">
            <ControlTemplate>
                <wm:ManagedWindow
                    Title="{TemplateBinding Title}"
                    WindowState="{TemplateBinding WindowState}"
                    SystemDecorations ="{TemplateBinding SystemDecorations}"
                    SizeToContent="{TemplateBinding SizeToContent}"
                    Topmost="{TemplateBinding Topmost}"
                    CanResize="{TemplateBinding CanResize}"
                    Width="{TemplateBinding Width}"
                    Height="{TemplateBinding Height}"
                    Background="{TemplateBinding Background}">
                    <Panel>
                        <!--<Border Name="PART_TransparencyFallback" IsHitTestVisible="False" />-->
                        <Border Background="{TemplateBinding Background}"
                                IsHitTestVisible="False" />
                        <!--<Panel Background="Transparent" Margin="{TemplateBinding WindowDecorationMargin}" /> -->
                        <VisualLayerManager>
                            <!--<VisualLayerManager.ChromeOverlayLayer>
                        <TitleBar />Red
                    </VisualLayerManager.ChromeOverlayLayer>-->
                            <ContentPresenter Name="PART_ContentPresenter"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Content="{TemplateBinding Content}"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </VisualLayerManager>
                    </Panel>
                </wm:ManagedWindow>
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>